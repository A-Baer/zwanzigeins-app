{
  "name": "zwanzigeins-app",
  "version": "0.1.0",
  "description": "Kopfrechen-Trainer für die unverdrehte Zahlensprechweise.",
  "type": "module",
  "main": "src/zwanzigeins-app.js",
  "scripts": {
    "test": "jasmine",
    "cap:prepare": "rm -rf web && mkdir -p web && rsync -a --delete index.html zwanzigeins-app.html manual.html speechmode-measuring.html service-worker.js web-manifest.json css js img mp3 res web/",
    "cap:sync:ios": "npm run cap:prepare && npx cap sync ios",
    "cap:open:ios": "npx cap open ios"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zwanzigeins-app/zwanzigeins-app.git"
  },
  "author": "Lukas Glowania",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/zwanzigeins-app/zwanzigeins-app/issues"
  },
  "homepage": "https://github.com/zwanzigeins-app/zwanzigeins-app#readme",
  "devDependencies": {
    "gulp": "^5.0.0",
    "gulp-better-rollup": "^4.0.1",
    "gulp-rev-all": "^3.0.0",
    "gulp-ssh": "^0.0.2",
    "gulp-uglifycss": "^1.1.0",
    "jasmine": "^5.2.0",
    "local-web-server": "^5.3.4",
    "rollup": "^1.32.1",
    "rollup-plugin-uglify-es": "0.0.1",
    "shelljs": "^0.8.4"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0"
  }
}
